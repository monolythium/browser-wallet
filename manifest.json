{
  "manifest_version": 3,
  "name": "Monolythium Browser Wallet",
  "short_name": "Monolythium",
  "version": "0.2.0",
  "description": "Self-custodial wallet for Monolythium. Post-quantum ML-DSA-65 signing, encrypted mempool, native Rust/RISC-V contract calls.",
  "homepage_url": "https://monolythium.com",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Monolythium Browser Wallet"
  },
  "side_panel": {
    "default_path": "src/popup/index.html?surface=sidepanel"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/provider.ts"
      ],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": [
        "<all_urls>"
      ],
      "js": [
        "src/content/bridge.ts"
      ],
      "run_at": "document_start"
    }
  ],
  "permissions": [
    "alarms",
    "storage",
    "sidePanel",
    "notifications",
    "clipboardWrite"
  ],
  "host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
