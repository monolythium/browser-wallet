{
  "manifest_version": 3,
  "name": "Monolythium Wallet",
  "version": "0.0.1",
  "description": "Monolythium v2 browser wallet",
  "action": {
    "default_popup": "src/popup/index.html",
    "default_title": "Monolythium Wallet"
  },
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/provider.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/bridge.ts"],
      "run_at": "document_start"
    }
  ],
  "permissions": ["alarms", "storage"],
  "icons": {
    "16": "icon-16.png",
    "48": "icon-48.png",
    "128": "icon-128.png"
  }
}
